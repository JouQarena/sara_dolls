# ============================================================
# 🌸 Sara Dolls — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# --- Supabase (Project Settings → API) ---
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe for the browser, protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin ---
# The email that is allowed into /admin (used in Phase 8).
ADMIN_EMAIL=

# --- Store / WhatsApp ---
# Admin WhatsApp number in international format WITHOUT + or spaces.
# Egypt example: 201001234567
NEXT_PUBLIC_WHATSAPP_NUMBER=201001234567

# Instapay handle/number shown at checkout (Phase 6).
NEXT_PUBLIC_INSTAPAY_NUMBER=

# Public site URL (used for metadata / sitemap in Phase 9).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
